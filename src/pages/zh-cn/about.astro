---
// 原项目：astro-theme-pure (Apache-2.0)
// 原作者：cworld1 (https://github.com/cworld1)
// 修改记录：
// 2026-02-15 修改者：创建关于页面，声明项目来源和许可证信息
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout meta={{}}>
  <div class="w-full py-2">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2 text-gray-900 dark:text-gray-100">关于本站</h1>
      <p class="text-gray-600 dark:text-gray-400">
        个人作品集与简历网站，展示专业历程、技术技能和个人项目。
      </p>
    </div>
    
    <div class="prose dark:prose-invert max-w-none">
      <!-- 站点介绍 -->
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">欢迎来访</h2>
        <p class="mb-4">
          这是一个个人作品集网站，使用现代 Web 技术构建，用于展示我的职业历程、工作经验和个人项目。网站支持中英文双语切换，界面简洁、响应式设计。
        </p>
        <p class="mb-4">
          欢迎浏览我的<a href="/zh-cn" class="text-primary underline hover:no-underline">简历</a>、<a href="/zh-cn/gallery" class="text-primary underline hover:no-underline">相册</a>，或访问我的<a href="https://likeit.dev" target="_blank" class="text-primary underline hover:no-underline">博客</a>了解更多内容。
        </p>
      </section>

      <!-- 功能特点 -->
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">功能特点</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 p-5 rounded-lg">
            <h3 class="text-lg font-medium mb-2">中英双语</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">无缝的中文/英文切换，全文翻译支持，方便全球访客浏览。</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 p-5 rounded-lg">
            <h3 class="text-lg font-medium mb-2">响应式设计</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">针对桌面、平板和移动设备优化，提供最佳的浏览体验。</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 p-5 rounded-lg">
            <h3 class="text-lg font-medium mb-2">深色/浅色模式</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">根据系统设置自动切换主题，也可手动切换。</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 p-5 rounded-lg">
            <h3 class="text-lg font-medium mb-2">快速加载</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">基于 Astro 构建，确保页面加载速度和 SEO 性能。</p>
          </div>
        </div>
      </section>

      <!-- 技术栈 -->
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">技术栈</h2>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">Astro 5</span>
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">React 19</span>
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">TypeScript</span>
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">Tailwind CSS</span>
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">Shiki</span>
          <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">Umami Analytics</span>
        </div>
      </section>

      <!-- 快速导航 -->
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">探索更多</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/zh-cn" class="block p-4 bg-gray-50 dark:bg-gray-800 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <h3 class="font-medium mb-1">在线简历</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">工作经历、教育背景、技能与项目</p>
          </a>
          <a href="/zh-cn/gallery" class="block p-4 bg-gray-50 dark:bg-gray-800 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <h3 class="font-medium mb-1">生活相册</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">照片收藏与美好回忆</p>
          </a>
          <a href="https://likeit.dev" target="_blank" class="block p-4 bg-gray-50 dark:bg-gray-800 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <h3 class="font-medium mb-1">技术博客</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">技术文章与心得分享</p>
          </a>
        </div>
      </section>

      <!-- 致谢 -->
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4">特别感谢</h2>
        <p class="mb-4">
          本站点基于 <a href="https://github.com/cworld1/astro-theme-pure" target="_blank" class="text-primary underline hover:no-underline">astro-theme-pure</a> 主题构建，由 <a href="https://github.com/cworld1" target="_blank" class="text-primary underline hover:no-underline">cworld1</a> 开发，采用 Apache License 2.0 开源许可。感谢开源社区提供的优秀工具和资源。
        </p>
      </section>

      <!-- 联系方式 -->
      <section class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-semibold mb-4">联系我</h2>
        <p class="mb-4">
          有合作意向或任何问题？欢迎通过以下方式联系我：
        </p>
        <ul class="list-none space-y-2">
          <li>
            <svg class="inline-block w-5 h-5 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            查看<a href="/zh-cn" class="text-primary underline hover:no-underline">简历页面</a>获取联系方式
          </li>
          <li>
            <svg class="inline-block w-5 h-5 mr-2 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <a href="https://github.com/save-soul/cv" target="_blank" class="text-primary underline hover:no-underline">GitHub 项目仓库</a>
          </li>
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>
