---
// 原项目：astro-theme-pure (Apache-2.0)
// 原作者：cworld1 (https://github.com/cworld1)
// 修改记录：
// 2026-04-16 修改者：优化导航栏，现代化桌面端样式和移动端汉堡菜单
import { siteConfig, menuLinks } from '@/config'
import { getCurrentLocale, getAlternateLanguageUrl } from '@/utils/locale'

const currentLocale = getCurrentLocale(Astro.url)
const isZhCn = currentLocale === 'zh-cn'
const currentSiteConfig = siteConfig[currentLocale]
const currentMenuLinks = menuLinks[currentLocale]
const alternateUrl = getAlternateLanguageUrl(Astro.url)

// 获取当前页面路径用于高亮
const currentPath = Astro.url.pathname
---

<header class='relative mb-6 w-full'>
  <nav
    class='flex items-center justify-between py-3'
    aria-label='global'
  >
    <!-- Logo 区域 -->
    <a
      class='text-xl font-bold tracking-tight text-foreground transition-opacity hover:opacity-70'
      href={isZhCn ? '/zh-cn/' : '/'}
      aria-label='Brand'
    >
      {currentSiteConfig.author}
    </a>

    <!-- 桌面端导航 -->
    <div class='hidden items-center gap-1 md:flex'>
      {
        currentMenuLinks.map((link) => {
          const isActive = currentPath.includes(link.path.replace('/', ''))
          return (
            <a
              href={link.path}
              class:list={[
                'relative px-4 py-2 text-sm font-medium transition-all rounded-lg',
                isActive
                  ? 'text-foreground bg-accent/50'
                  : 'text-foreground/70 hover:text-foreground hover:bg-accent/30'
              ]}
              aria-label={link.title}
              target={link.isBlank ? '_blank' : '_self'}
            >
              {link.title}
              {link.isBlank && (
                <svg class='ml-0.5 inline-block h-3 w-3' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
                  <path d='M7 17L17 7M17 7H7M17 7V17' />
                </svg>
              )}
            </a>
          )
        })
      }

      <!-- 分隔线 -->
      <div class='mx-2 h-6 w-px bg-border'></div>

      <!-- 语言切换 -->
      <a
        href={alternateUrl}
        class='group flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-foreground/70 transition-all hover:bg-accent/30 hover:text-foreground'
        title={isZhCn ? 'Switch to English' : '切换到中文'}
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='18'
          height='18'
          viewBox='0 0 24 24'
          class='transition-transform group-hover:rotate-45'
        >
          <path
            fill='currentColor'
            d='M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0 0 14.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z'
          ></path>
        </svg>
        <span class='hidden lg:inline'>{isZhCn ? 'EN' : '中文'}</span>
      </a>

      <!-- 主题切换 -->
      <button
        id='toggleDarkMode'
        class='rounded-lg p-2 text-foreground/70 transition-all hover:bg-accent/30 hover:text-foreground'
        aria-label='Toggle theme'
      >
        <!-- 太阳图标 -->
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          class='h-5 w-5 transition-all dark:hidden'
        >
          <circle cx='12' cy='12' r='4' fill='currentColor'></circle>
          <path
            fill='currentColor'
            d='M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41M12 6a6 6 0 1 0 0 12 6 6 0 0 0 0-12z'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
          ></path>
        </svg>
        <!-- 月亮图标 -->
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          class='hidden h-5 w-5 transition-all dark:block'
        >
          <path
            fill='currentColor'
            d='M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998z'
          ></path>
        </svg>
      </button>
    </div>

    <!-- 移动端控制按钮 -->
    <div class='flex items-center gap-1 md:hidden'>
      <!-- 主题切换 (移动端) -->
      <button
        id='toggleDarkModeMobile'
        class='rounded-lg p-2 text-foreground/70 transition-all hover:bg-accent/30 hover:text-foreground'
        aria-label='Toggle theme'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          class='h-5 w-5 transition-all dark:hidden'
        >
          <circle cx='12' cy='12' r='4' fill='currentColor'></circle>
          <path
            fill='currentColor'
            d='M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41M12 6a6 6 0 1 0 0 12 6 6 0 0 0 0-12z'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
          ></path>
        </svg>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          class='hidden h-5 w-5 transition-all dark:block'
        >
          <path
            fill='currentColor'
            d='M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998z'
          ></path>
        </svg>
      </button>

      <!-- 汉堡菜单按钮 -->
      <button
        id='hamburger'
        class='flex h-10 w-10 items-center justify-center rounded-xl bg-accent/50 transition-all hover:bg-accent active:scale-95'
        aria-label={isZhCn ? '打开菜单' : 'Open menu'}
        aria-expanded='false'
      >
        <div class='hamburger-icon relative h-5 w-5'>
          <span class='hamburger-line absolute left-0 top-0 h-0.5 w-5 bg-foreground transition-all duration-300'></span>
          <span class='hamburger-line absolute left-0 top-2 h-0.5 w-5 bg-foreground transition-all duration-300'></span>
          <span class='hamburger-line absolute left-0 top-4 h-0.5 w-5 bg-foreground transition-all duration-300'></span>
        </div>
      </button>
    </div>
  </nav>
</header>

<!-- 移动端抽屉菜单遮罩 -->
<div id='menu-overlay' class='fixed inset-0 z-40 hidden bg-black/50 opacity-0 backdrop-blur-sm transition-opacity duration-300 md:hidden'></div>

<!-- 移动端抽屉菜单 -->
<div
  id='mobile-menu'
  class='fixed bottom-0 right-0 top-0 z-50 w-72 max-w-[85vw] translate-x-full bg-background shadow-2xl transition-transform duration-300 ease-out md:hidden'
>
  <div class='flex h-full flex-col'>
    <!-- 菜单头部 -->
    <div class='flex items-center justify-between border-b border-border px-6 py-5'>
      <span class='text-lg font-semibold'>{isZhCn ? '菜单' : 'Menu'}</span>
      <button
        id='menu-close'
        class='flex h-9 w-9 items-center justify-center rounded-lg bg-accent/50 transition-all hover:bg-accent active:scale-95'
        aria-label={isZhCn ? '关闭菜单' : 'Close menu'}
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          class='transition-transform'
        >
          <line x1='18' y1='6' x2='6' y2='18'></line>
          <line x1='6' y1='6' x2='18' y2='18'></line>
        </svg>
      </button>
    </div>

    <!-- 菜单内容 -->
    <div class='flex-1 overflow-y-auto px-4 py-6'>
      <div class='space-y-1'>
        {
          currentMenuLinks.map((link) => {
            const isActive = currentPath.includes(link.path.replace('/', ''))
            return (
              <a
                href={link.path}
                class:list={[
                  'group flex items-center justify-between rounded-xl px-4 py-3 text-base font-medium transition-all',
                  isActive
                    ? 'bg-accent/50 text-foreground'
                    : 'text-foreground/70 hover:bg-accent/30 hover:text-foreground'
                ]}
                aria-label={link.title}
                target={link.isBlank ? '_blank' : '_self'}
              >
                <span>{link.title}</span>
                {isActive && (
                  <div class='h-2 w-2 rounded-full bg-foreground'></div>
                )}
                {link.isBlank && (
                  <svg class='h-4 w-4 opacity-50' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
                    <path d='M7 17L17 7M17 7H7M17 7V17' />
                  </svg>
                )}
              </a>
            )
          })
        }
      </div>
    </div>

    <!-- 菜单底部 -->
    <div class='border-t border-border p-4'>
      <a
        href={alternateUrl}
        class='flex w-full items-center justify-center gap-2 rounded-xl bg-accent/50 px-4 py-3 text-base font-medium text-foreground transition-all hover:bg-accent active:scale-[0.98]'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='18'
          height='18'
          viewBox='0 0 24 24'
        >
          <path
            fill='currentColor'
            d='M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0 0 14.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z'
          ></path>
        </svg>
        {isZhCn ? '切换到 English' : '切换到中文'}
      </a>
    </div>
  </div>
</div>

<script is:inline>
  // 主题切换
  function getCurrentTheme() {
    const isDark = document.documentElement.classList.contains('dark')
    return isDark ? 'dark' : 'light'
  }

  function setupThemeToggle(buttonId) {
    const button = document.getElementById(buttonId)
    button?.addEventListener('click', () => {
      const theme = getCurrentTheme() === 'light' ? 'dark' : 'light'
      const toggleDarkModeEvent = new CustomEvent('theme-change', {
        detail: { theme }
      })
      document.dispatchEvent(toggleDarkModeEvent)
    })
  }

  // 移动端菜单
  function setupMobileMenu() {
    const hamburger = document.getElementById('hamburger')
    const menuClose = document.getElementById('menu-close')
    const mobileMenu = document.getElementById('mobile-menu')
    const overlay = document.getElementById('menu-overlay')

    function openMenu() {
      if (!mobileMenu || !overlay) return
      mobileMenu.classList.remove('translate-x-full')
      overlay.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
      setTimeout(() => {
        overlay.classList.remove('opacity-0')
      }, 10)
      hamburger?.setAttribute('aria-expanded', 'true')
      // 切换为关闭图标
      const lines = hamburger?.querySelectorAll('.hamburger-line')
      if (lines && lines.length === 3) {
        lines[0].style.transform = 'rotate(45deg) translate(5px, 5px)'
        lines[1].style.opacity = '0'
        lines[2].style.transform = 'rotate(-45deg) translate(5px, -5px)'
      }
    }

    function closeMenu() {
      if (!mobileMenu || !overlay) return
      overlay.classList.add('opacity-0')
      setTimeout(() => {
        mobileMenu.classList.add('translate-x-full')
        overlay.classList.add('hidden')
        document.body.style.overflow = ''
      }, 300)
      hamburger?.setAttribute('aria-expanded', 'false')
      // 切换回汉堡图标
      const lines = hamburger?.querySelectorAll('.hamburger-line')
      if (lines && lines.length === 3) {
        lines[0].style.transform = ''
        lines[1].style.opacity = '1'
        lines[2].style.transform = ''
      }
    }

    hamburger?.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true'
      if (isOpen) {
        closeMenu()
      } else {
        openMenu()
      }
    })

    menuClose?.addEventListener('click', closeMenu)
    overlay?.addEventListener('click', closeMenu)

    // ESC 键关闭菜单
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu()
    })

    // 点击菜单项关闭菜单
    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu)
    })
  }

  // 初始化
  function initHeader() {
    setupThemeToggle('toggleDarkMode')
    setupThemeToggle('toggleDarkModeMobile')
    setupMobileMenu()
  }

  initHeader()

  document.addEventListener('astro:after-swap', () => {
    initHeader()
  })
</script>

<style>
  /* 汉堡菜单动画 */
  .hamburger-icon .hamburger-line {
    transform-origin: center;
  }

  /* 抽屉菜单滑入动画 */
  #mobile-menu {
    will-change: transform;
  }

  /* 遮罩平滑过渡 */
  #menu-overlay {
    will-change: opacity;
  }

  /* 滚动条美化 */
  #mobile-menu::-webkit-scrollbar {
    width: 4px;
  }

  #mobile-menu::-webkit-scrollbar-track {
    background: transparent;
  }

  #mobile-menu::-webkit-scrollbar-thumb {
    background: rgb(var(--border));
    border-radius: 4px;
  }
</style>
