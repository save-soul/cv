---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/app.css'

import type { SiteMeta, Locale } from '@/types'
import { siteConfig, galleryConfig } from '@/config'

type Props = SiteMeta & {
	title?: string
	currentLocale?: Locale
}

const { articleDate, description, ogImage, title, currentLocale } = Astro.props

// 获取当前语言的站点配置
const currentSiteConfig = currentLocale ? siteConfig[currentLocale] : siteConfig['zh-cn']

const siteTitle = title || currentSiteConfig.title
const siteDescription = description || currentSiteConfig.description
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const socialImageURL = new URL(ogImage ? ogImage : '/social-card.png', Astro.url).href

// 根据页面路径确定页面类型
const pathname = Astro.url.pathname
const isGalleryPage = pathname.includes('/gallery')
const galleryImages = galleryConfig[currentLocale || 'en'].images
---

<meta charset='utf-8' />
<meta content='width=device-width, initial-scale=1.0, shrink-to-fit=no' name='viewport' />
<meta content='IE=edge' http-equiv='X-UA-Compatible' />
<title>{siteTitle}</title>

{/* Icons / Favicon */}
<link rel='icon' href='/favicon/favicon.ico' sizes='any' />
<link rel='icon' href='/favicon/android-chrome-192x192.png' sizes='192x192' />
<link rel='icon' href='/favicon/android-chrome-512x512.png' sizes='512x512' />
<link rel='apple-touch-icon' sizes='1350x1350' href='/favicon/apple-touch-icon.png' />
<link rel='manifest' href='/manifest.json' />

{/* Canonical URL */}
<link rel='canonical' href={canonicalURL} />

{/* Primary Meta Tags */}
<meta content={siteTitle} name='title' />
<meta content={siteDescription} name='description' />
<meta content={currentSiteConfig.author} name='author' />
<meta
	name='keywords'
	content={Array.isArray(currentSiteConfig.keywords)
		? currentSiteConfig.keywords.join(', ')
		: currentSiteConfig.keywords}
/>
<meta name='robots' content='index, follow, max-image-preview=large, max-snippet=-1, max-video-preview=-1' />
<meta name='googlebot' content='index, follow' />

{/* Theme Colour */}
<meta content='#ffffff' name='theme-color' media='(prefers-color-scheme: light)' />
<meta content='#1a1a1a' name='theme-color' media='(prefers-color-scheme: dark)' />

{/* Geographic Meta Tags for GEO SEO */}
<meta content='CN' name='geo.region' />
<meta content='Guangzhou' name='geo.placename' />
<meta content='23.1291;113.2644' name='geo.position' />
<meta content='Guangzhou, China' name='ICBM' />

{/* Open Graph / Facebook */}
<meta content={articleDate ? 'article' : 'website'} property='og:type' />
<meta content={siteTitle} property='og:title' />
<meta content={siteDescription} property='og:description' />
<meta content={canonicalURL} property='og:url' />
<meta content={currentSiteConfig.title} property='og:site_name' />
<meta content={currentSiteConfig.ogLocale} property='og:locale' />
<meta content={socialImageURL} property='og:image' />
<meta content='1200' property='og:image:width' />
<meta content='630' property='og:image:height' />
<meta content='image/png' property='og:image:type' />
{
	articleDate && (
		<>
			<meta content={currentSiteConfig.author} property='article:author' />
			<meta content={articleDate} property='article:published_time' />
		</>
	)
}

{/* Twitter */}
<meta content='summary_large_image' property='twitter:card' />
<meta content={canonicalURL} property='twitter:url' />
<meta content={siteTitle} property='twitter:title' />
<meta content={siteDescription} property='twitter:description' />
<meta content={socialImageURL} property='twitter:image' />
<meta content='Zhao Wenguang' property='twitter:site' />

{/* Hreflang tags for internationalization */}
<link href={canonicalURL} hreflang={currentLocale === 'zh-cn' ? 'zh-CN' : 'en'} rel='alternate' />
{
	currentSiteConfig.otherLanguages.map((lang) => (
		<link href={new URL(`${lang.url}`, canonicalURL).href} hreflang={lang.lang} rel='alternate' />
	))
}
<link href={new URL('/', canonicalURL).href} hreflang='x-default' rel='alternate' />
{/* Additional hreflang for language-region variants */}
<link href={new URL('/', canonicalURL).href} hreflang='zh' rel='alternate' />
<link href={new URL('/zh-cn/', canonicalURL).href} hreflang='zh-CN' rel='alternate' />
{/* Sitemap */}
<link href='/sitemap.xml' rel='sitemap' type='application/xml' />

<meta content={Astro.generator} name='generator' />

{/* Schema.org structured data */}
{
	currentSiteConfig.schemaOrg && (
		<script type='application/ld+json' is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Person",
					"@id": "https://zwg.me/#person",
					"name": currentSiteConfig.schemaOrg.person.name,
					"alternateName": currentSiteConfig.schemaOrg.person.alternateName,
					"url": "https://zwg.me/",
					"image": {
						"@type": "ImageObject",
						"url": "https://zwg.me/favicon/avatar.png",
						"width": 192,
						"height": 192
					},
					"sameAs": ["https://likeit.dev"],
					"jobTitle": currentSiteConfig.schemaOrg.person.jobTitle,
					"description": currentSiteConfig.schemaOrg.person.description,
					"knowsAbout": currentSiteConfig.schemaOrg.person.knowsAbout,
					"mainEntityOfPage": {
						"@type": "WebPage",
						"@id": "https://zwg.me/"
					},
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Guangzhou",
						"addressRegion": "Guangdong",
						"addressCountry": "CN"
					},
					"nationality": {
						"@type": "Country",
						"name": "China"
					}
				},
				{
					"@type": "Place",
					"@id": "https://zwg.me/#place",
					"name": "Guangzhou, Guangdong, China",
					"description": "Location of Zhao Wenguang",
					"geo": {
						"@type": "GeoCoordinates",
						"latitude": 23.1291,
						"longitude": 113.2644
					},
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Guangzhou",
						"addressRegion": "Guangdong",
						"addressCountry": "CN"
					}
				},
				{
					"@type": "WebSite",
					"@id": "https://zwg.me/#website",
					"url": "https://zwg.me/",
					"name": currentSiteConfig.schemaOrg.website.name,
					"description": currentSiteConfig.schemaOrg.website.description,
					"publisher": {"@id": "https://zwg.me/#person"},
					"inLanguage": ["en", "zh-CN"],
					"potentialAction": {
						"@type": "SearchAction",
						"target": "https://zwg.me/search?q={search_term_string}",
						"query-input": "required name=search_term_string"
					}
				},
				{
					"@type": "WebPage",
					"@id": canonicalURL.href,
					"url": canonicalURL.href,
					"name": siteTitle,
					"description": siteDescription,
					"isPartOf": {"@id": "https://zwg.me/#website"},
					"inLanguage": currentLocale === 'zh-cn' ? 'zh-CN' : 'en',
					"datePublished": articleDate || undefined,
					...(isGalleryPage && galleryImages.length > 0 ? {
						"@type": "ImageGallery",
						"name": siteTitle,
						"description": siteDescription,
						"associatedMedia": galleryImages.map(img => ({
							"@type": "ImageObject",
							"url": img.src,
							"name": img.title,
							"description": img.description || img.title
						}))
					} : {})
				}
			]
		})} />
	)
}
